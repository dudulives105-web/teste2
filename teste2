-- ══════════════════════════════════════════
--  ANTI VOID / PLATAFORMA
-- ══════════════════════════════════════════
local antiVoidEnabled  = false
local antiVoidPlatform = nil
local antiVoidConnection = nil
local antiVoidPaused   = false

local VOID_THRESHOLD = -18
local PLATFORM_SIZE  = Vector3.new(50, 2, 50)
local PLATFORM_Y     = -13

local function createPlatform(char)
    if antiVoidPlatform and antiVoidPlatform.Parent then
        antiVoidPlatform:Destroy()
    end
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local part = Instance.new("Part")
    part.Name          = "AntiVoidPlatform"
    part.Size          = PLATFORM_SIZE
    part.Anchored      = true
    part.CanCollide    = true
    part.Transparency  = 1
    part.Material      = Enum.Material.SmoothPlastic
    part.Color         = Color3.fromRGB(80, 30, 180)
    part.CastShadow    = false
    part.CanQuery      = false
    part.CFrame        = CFrame.new(root.Position.X, PLATFORM_Y, root.Position.Z)
    part.Parent        = workspace

    antiVoidPlatform = part
    return part
end

local function destroyPlatform()
    if antiVoidPlatform and antiVoidPlatform.Parent then
        antiVoidPlatform:Destroy()
    end
    antiVoidPlatform = nil
end

local function enableAntiVoid()
    antiVoidEnabled = true
    local char = player.Character
    if char then createPlatform(char) end

    if antiVoidConnection then antiVoidConnection:Disconnect() end

    antiVoidConnection = RunService.Heartbeat:Connect(function()
        if antiVoidPaused then return end

        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then return end

        if antiVoidPlatform and antiVoidPlatform.Parent then
            antiVoidPlatform.CFrame = CFrame.new(
                root.Position.X,
                PLATFORM_Y,
                root.Position.Z
            )
        end

        if root.Position.Y < VOID_THRESHOLD then
            root.CFrame = CFrame.new(root.Position.X, PLATFORM_Y + 5, root.Position.Z)
        end
    end)
end

local function disableAntiVoid()
    antiVoidEnabled = false
    if antiVoidConnection then
        antiVoidConnection:Disconnect()
        antiVoidConnection = nil
    end
    destroyPlatform()
end

-- ══════════════════════════════════════════
--  AUTO-TP NO TAPA (knockback detector)
-- ══════════════════════════════════════════
local tapaTpEnabled       = false
local tapaConnection      = nil
local lastVelocity        = Vector3.new(0,0,0)
local KNOCKBACK_THRESHOLD = 35
local tapaCooldown        = false

local function startTapaDetector()
    if tapaConnection then tapaConnection:Disconnect() end
    lastVelocity = Vector3.new(0,0,0)

    tapaConnection = RunService.Heartbeat:Connect(function()
        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        if tapaCooldown then return end

        local vel       = root.AssemblyLinearVelocity
        local speed     = Vector3.new(vel.X, 0, vel.Z).Magnitude
        local prevSpeed = Vector3.new(lastVelocity.X, 0, lastVelocity.Z).Magnitude
        local delta     = speed - prevSpeed

        if delta > KNOCKBACK_THRESHOLD then
            tapaCooldown   = true
            antiVoidPaused = true

            local savedCFrame = root.CFrame

            task.spawn(function()
                task.wait(0.05)
                local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if r then
                    r.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    r.CFrame = savedCFrame
                end

                if antiVoidPlatform and antiVoidPlatform.Parent then
                    antiVoidPlatform.CFrame = CFrame.new(
                        savedCFrame.Position.X,
                        PLATFORM_Y,
                        savedCFrame.Position.Z
                    )
                end

                antiVoidPaused = false
                task.wait(0.4)
                tapaCooldown = false
            end)
        end

        lastVelocity = vel
    end)
end

local function stopTapaDetector()
    if tapaConnection then
        tapaConnection:Disconnect()
        tapaConnection = nil
    end
    lastVelocity   = Vector3.new(0,0,0)
    antiVoidPaused = false
end

