--  TP AO SPAWN AO PEGAR BRAINROT
-- ══════════════════════════════════════════
local brainrotTpEnabled  = false
-- ► NOVO: flag de kick exclusiva para brainrot
local brainrotKickEnabled = false

local brainrotConnection = nil

local BRAINROT_KEYS = {
    "strawberry","elephant","dragon","cannelloni","vacca","saturno",
    "saturnita","chicleteira","bicicleteira","nuclearo","dinossauro",
    "meowl","skibidi","toilet","brainrot","tralalero","bombardiro",
    "tung","bombombini","lirili","frigo","glorbo","capuchino","trippi",
    "crocodilo","sahur",
}

local function isBrainrotItem(name)
    name = name:lower()
    for _, k in ipairs(BRAINROT_KEYS) do
        if name:find(k, 1, true) then return true end
    end
    return false
end

local tpCooldown = false

-- ► MODIFICADO: após o TP, aplica kick de brainrot se ativado
local function doTpToSpawn()
    if tpCooldown then return end
    if not spawnPosition then return end
    tpCooldown = true

    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root then
        root.CFrame = spawnPosition
    end

    -- Kick exclusivo do brainrot (independente do kickAfterTP geral)
    if brainrotKickEnabled then
        task.wait(0.3)
        player:Kick("Desconectado.")
        return  -- após kick não precisa resetar cooldown
    end

    task.delay(1.5, function() tpCooldown = false end)
end

local function isWeldedToChar(obj, char)
    for _, desc in ipairs(obj:GetDescendants()) do
        if desc:IsA("WeldConstraint") or desc:IsA("Weld") then
            local p0, p1 = desc.Part0, desc.Part1
            if p0 and p1 then
                if p0:IsDescendantOf(char) or p1:IsDescendantOf(char) then
                    return true
                end
            end
        end
    end
    return false
end

local watchConnections = {}

local function startBrainrotDetector()
    for _, c in ipairs(watchConnections) do c:Disconnect() end
    watchConnections = {}

    if brainrotConnection then brainrotConnection:Disconnect() end

    local function watchChar(char)
        if not char then return end
        local c1 = char.ChildAdded:Connect(function(obj)
            if not brainrotTpEnabled then return end
            task.wait(0.05)
            if isBrainrotItem(obj.Name) then
                print("[BrainrotTP] No char:", obj.Name)
                doTpToSpawn()
            end
        end)
        local c2 = char.DescendantAdded:Connect(function(obj)
            if not brainrotTpEnabled then return end
            if isBrainrotItem(obj.Name) then
                print("[BrainrotTP] Descendente no char:", obj.Name)
                doTpToSpawn()
            end
        end)
        table.insert(watchConnections, c1)
        table.insert(watchConnections, c2)
    end

    local function watchBackpack()
        local bp = player:FindFirstChild("Backpack") or player:WaitForChild("Backpack", 5)
        if not bp then return end
        local c = bp.ChildAdded:Connect(function(obj)
            if not brainrotTpEnabled then return end
            if isBrainrotItem(obj.Name) then
                print("[BrainrotTP] No backpack:", obj.Name)
                doTpToSpawn()
            end
        end)
        table.insert(watchConnections, c)
    end

    brainrotConnection = task.spawn(function()
        while brainrotTpEnabled do
            task.wait(0.2)
            if not brainrotTpEnabled then break end
            if tpCooldown then continue end

            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if not char or not root then continue end

            for _, obj in ipairs(workspace:GetChildren()) do
                if obj == char then continue end
                local part = obj:IsA("BasePart") and obj
                    or (obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")))
                if not part then continue end

                local ok, dist = pcall(function()
                    return (root.Position - part.Position).Magnitude
                end)
                if not ok then continue end

                if dist < 5 then
                    if isBrainrotItem(obj.Name) then
                        print("[BrainrotTP] Próximo workspace:", obj.Name, dist)
                        doTpToSpawn()
                        break
                    elseif isWeldedToChar(obj, char) then
                        print("[BrainrotTP] Welded ao char:", obj.Name)
                        doTpToSpawn()
                        break
                    end
                end
            end
        end
    end)

    watchChar(player.Character)
    watchBackpack()

    local rc = player.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        watchChar(char)
    end)
    table.insert(watchConnections, rc)
end

local function stopBrainrotDetector()
    brainrotTpEnabled = false
    for _, c in ipairs(watchConnections) do c:Disconnect() end
    watchConnections = {}
    brainrotConnection = nil
end

