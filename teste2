function setNoclip(state)
    noclipActive = state
    if state then
        noclipToggle.Text = "☑  Noclip"
        noclipToggle.TextColor3 = Color3.fromRGB(100, 220, 255)
        noclipStroke.Color = Color3.fromRGB(50, 130, 200)
        noclipToggle.BackgroundColor3 = Color3.fromRGB(10, 18, 28)
        noclipConnection = RunService.Stepped:Connect(function()
            local char = player.Character
            if char then
                for _, p in ipairs(char:GetDescendants()) do
                    if p:IsA("BasePart") then p.CanCollide = false end
                end
            end
        end)
    else
        noclipToggle.Text = "☐  Noclip"
        noclipToggle.TextColor3 = Color3.fromRGB(150, 150, 150)
        noclipStroke.Color = Color3.fromRGB(50, 50, 50)
        noclipToggle.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
        if noclipConnection then
            noclipConnection:Disconnect()
            noclipConnection = nil
        end
        local char = player.Character
        if char then
            for _, p in ipairs(char:GetDescendants()) do
                if p:IsA("BasePart") then p.CanCollide = true end
            end
        end
    end
end

